<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Home screen — scrollable list of rooms with their device cards.
  Cards are built dynamically by HomeController based on the live hub state.
-->
<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthome.ui.HomeController"
            styleClass="main-scroll"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED">

  <content>
    <VBox fx:id="roomsContainer" styleClass="content-pane" spacing="16">
      <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
      <!-- Rooms and their cards are appended here at runtime. -->
    </VBox>
  </content>

</ScrollPane>
