<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  M3 dialog — adding a new device to a room.
  Demonstrates Abstract Factory + DAO at runtime: the user picks a
  (type, family) tuple, the matching factory creates the device, and
  DeviceDAO persists it.
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smarthome.ui.AddDeviceController"
      styleClass="content-pane"
      spacing="16"
      prefWidth="340">

  <padding><Insets top="24" right="24" bottom="20" left="24"/></padding>

  <Label fx:id="titleLabel" text="Add a device"
         styleClass="room-name"/>

  <Label text="Pattern in action: Abstract Factory + DAO"
         styleClass="pattern-caption" wrapText="true"/>

  <VBox spacing="6">
    <Label text="DEVICE TYPE" styleClass="form-label"/>
    <ChoiceBox fx:id="typeChoice" maxWidth="Infinity"/>
  </VBox>

  <VBox spacing="6">
    <Label text="FAMILY" styleClass="form-label"/>
    <ChoiceBox fx:id="familyChoice" maxWidth="Infinity"/>
  </VBox>

  <VBox spacing="6">
    <Label text="NAME" styleClass="form-label"/>
    <TextField fx:id="nameField" promptText="e.g. Bedside Lamp"/>
  </VBox>

  <Label fx:id="errorLabel" styleClass="pattern-caption"
         wrapText="true" text=""/>

  <Region VBox.vgrow="ALWAYS"/>

  <!-- M3 dialog actions: right-aligned, text + filled button -->
  <HBox spacing="8" alignment="CENTER_RIGHT">
    <Button text="Cancel" onAction="#onCancel"
            styleClass="action-button"/>
    <Button text="Add device" onAction="#onAdd"
            styleClass="action-button-primary, action-button"/>
  </HBox>
</VBox>
